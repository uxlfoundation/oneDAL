/*
 * Version script for libonedal.so (oneAPI C++ Interface)
 *
 * This file explicitly defines which symbols are exported from libonedal.so
 */

ONEDAL_2026.0 {
global:
    extern "C++" {
        # Public oneAPI interface - export all algorithm namespaces
        "oneapi::dal::*";

        # Explicitly exclude backend implementation
        "!oneapi::dal::backend::*";
        "!oneapi::dal::*::backend::*";
    };

local:
    # Hide everything else by default
    *;
};
